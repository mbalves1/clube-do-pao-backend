generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  phone            String?
  zipCode          String?
  street           String?
  number           String?
  district         String?
  city             String?
  state            String?
  favoriteBakeries FavoriteBakery[]
  appointments     Subscription[]
  createdAt        DateTime         @default(now())
}

model Bakery {
  id             String           @id @default(uuid())
  name           String
  cnpj           String
  email          String           @unique
  phone          String
  whatsapp       String
  serviceStartAt String
  serviceEndAt   String
  zipCode        String?
  street         String?
  number         String?
  district       String?
  city           String?
  state          String?
  favorites      FavoriteBakery[]
  appointments   Subscription[]
  createdAt      DateTime         @default(now())

  @@map("bakeries")
}

model FavoriteBakery {
  id        String   @id @default(uuid())
  userId    String
  bakeryId  String
  user      User     @relation(fields: [userId], references: [id])
  bakery    Bakery   @relation(fields: [bakeryId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, bakeryId])
  @@map("favoriteBakery")
}

model Subscription {
  id              Int @id @default(autoincrement())
  userId          String
  bakeryId        String
  user            User     @relation(fields: [userId], references: [id])
  bakery          Bakery   @relation(fields: [bakeryId], references: [id])
  serviceDate     DateTime @default(now())
  serviceStartAt  String
  serviceEndAt    String
  deliveryStartAt String
  deliveryEndAt   String
  status          String   @default("pending")
  notes           String?
  frequency       String
  daysWeek        String[]
  createdAt       DateTime @default(now())

  @@map("subscription")
}
